<Window x:Class="BlocDeNotas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bloc de Notas" Height="450" Width="800">
    <Grid>
        <!-- Menú superior -->
        <Menu VerticalAlignment="Top">
            <MenuItem Header="Archivo">
                <MenuItem Header="Limpiar" Click="LimpiarMenuItem_Click"/>
                <MenuItem Header="Abrir" Click="AbrirMenuItem_Click"/>
                <MenuItem Header="Guardar" Click="GuardarMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- Caja de texto para el contenido -->
        <TextBox Name="textBox" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,30,0,0" AcceptsReturn="True" />
    </Grid>
</Window>